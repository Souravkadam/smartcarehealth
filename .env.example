# MongoDB connection string
# Local:   mongodb://localhost:27017/smartcare
# Atlas:   mongodb+srv://<user>:<password>@cluster.mongodb.net/smartcare
MONGODB_URI=mongodb://localhost:27017/smartcare

PORT=3001
NODE_ENV=development

# Razorpay — get from https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_REPLACE_ME
RAZORPAY_KEY_SECRET=REPLACE_ME_SECRET
RAZORPAY_WEBHOOK_SECRET=REPLACE_ME_WEBHOOK_SECRET
